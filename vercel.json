{
	"headers": [
		{
			"source": "/(.*)",
			"headers": [
				{
					"key": "Strict-Transport-Security",
					"value": "max-age=31536000; includeSubDomains; preload"
				},
				{
					"key": "X-Content-Type-Options",
					"value": "nosniff"
				},
				{
					"key": "X-Frame-Options",
					"value": "SAMEORIGIN"
				},
				{
					"key": "Referrer-Policy",
					"value": "strict-origin-when-cross-origin"
				},
				{
					"key": "Permissions-Policy",
					"value": "camera=(), microphone=(), geolocation=()"
				}
			]
		}
	],
	"redirects": [
		{ "source": "/sitio-web-huancavelica", "destination": "/", "statusCode": 301 },
		{ "source": "/sitio-web-huancayo", "destination": "/", "statusCode": 301 },
		{ "source": "/desarrollo-web-huancavelica", "destination": "/", "statusCode": 301 },
		{ "source": "/desarrollo-web-huancayo", "destination": "/", "statusCode": 301 },
		{ "source": "/pagina-web-huancavelica", "destination": "/", "statusCode": 301 },
		{ "source": "/pagina-web-huancayo", "destination": "/", "statusCode": 301 },
		{ "source": "/proyectos/sistema-gestion-academica", "destination": "/proyectos", "statusCode": 301 },
		{ "source": "/proyectos/asistente-inteligente-peralta-asociados", "destination": "/proyectos/peralta-asociados", "statusCode": 301 },
		{ "source": "/proyectos/pagina-web-peralta-asociados", "destination": "/proyectos/peralta-asociados", "statusCode": 301 }
	]
}
